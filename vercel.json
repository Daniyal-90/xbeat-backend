{
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/v1/(.*)", "dest": "/api/index.js" }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "routes/**",
        "controllers/**",
        "models/**",
        "middleware/**",
        "utils/**",
        "shared/**",
        "api/**"
      ]
    }
  }
}